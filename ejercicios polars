        "# Ejercicio 10\n",
        "# Crear categoría\n",
        "df_category = df.with_columns(\n",
        "    pl.when(pl.col(\"age\") < 30)\n",
        "    .then(pl.lit(\"Young\"))\n",
        "    .otherwise(pl.lit(\"Senior\"))\n",
        "    .alias(\"category\")\n",
        ")\n",
        "\n",
        "print(df_category)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "MWIOiwTTOGIi",
        "outputId": "eaaaefd9-f9a3-4040-84ec-83b98a0e46d5"
      },
      "execution_count": 15,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "shape: (3, 3)\n",
            "┌─────────┬─────┬──────────┐\n",
            "│ name    ┆ age ┆ category │\n",
            "│ ---     ┆ --- ┆ ---      │\n",
            "│ str     ┆ i64 ┆ str      │\n",
            "╞═════════╪═════╪══════════╡\n",
            "│ Anna    ┆ 25  ┆ Young    │\n",
            "│ Bob     ┆ 30  ┆ Senior   │\n",
            "│ Charlie ┆ 35  ┆ Senior   │\n",
            "└─────────┴─────┴──────────┘\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Explicación\n",
        "\n",
        "1. pl.when(pl.col(\"age\") < 30)\n",
        "\n",
        "Evalúa la condición:\n",
        "\n",
        "age < 30\n",
        "\n",
        "2. .then(pl.lit(\"Young\")):\n",
        "\n",
        "pl.lit() significa:\n",
        "\n",
        "“esto es un valor literal”\n",
        "\n",
        "Entonces:\n",
        "\n",
        "pl.lit(\"Young\")\n",
        "\n",
        "le dice a Polars que \"Young\" es texto y no una columna.\n",
        "\n",
        "3. .otherwise(pl.lit(\"Senior\"))\n",
        "\n",
        "Si la condición no se cumple:\n",
        "\n",
        "\"Senior\"\n",
        "4. .alias(\"category\")\n",
        "\n",
        "Da nombre a la nueva columna."
      ],
