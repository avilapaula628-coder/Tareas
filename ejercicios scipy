        "# Ejercicio 1\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "\n",
        "# Datos\n",
        "data = np.array([23, 45, 67, 89, 12, 34, 56, 78, 90, 21, 43, 65, 87, 9,\n",
        "32, 54, 76, 98, 10, 31])\n",
        "\n",
        "# Cálculos\n",
        "n = len(data)\n",
        "min_val = np.min(data)\n",
        "max_val = np.max(data)\n",
        "mean_val = np.mean(data)\n",
        "var_val = np.var(data)\n",
        "skew_val = stats.skew(data)\n",
        "kurt_val = stats.kurtosis(data)\n",
        "\n",
        "# Resultados\n",
        "print(\"Número de observaciones:\", n)\n",
        "print(\"Mínimo:\", min_val)\n",
        "print(\"Máximo:\", max_val)\n",
        "print(\"Media:\", mean_val)\n",
        "print(\"Varianza:\", var_val)\n",
        "print(\"Skewness:\", skew_val)\n",
        "print(\"Kurtosis:\", kurt_val)\n"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Explicación:\n",
        "\n",
        "np.array() → crea el conjunto de datos\n",
        "\n",
        "len(data) → cuenta cuántos datos hay\n",
        "\n",
        "np.min() / np.max() → valor más pequeño y más grande\n",
        "\n",
        "np.mean() → promedio\n",
        "\n",
        "np.var() → qué tan dispersos están los datos\n",
        "🔹 Medidas avanzadas:\n",
        "stats.skew() → mide asimetría\n",
        "\n",
        "0 → sesgo a la derecha\n",
        "\n",
        "< 0 → sesgo a la izquierda\n",
        "stats.kurtosis() → mide forma de la distribución\n",
        "\n",
        "0 → más picuda (leptocúrtica)\n",
        "\n",
        "< 0 → más plana (platicúrtica)"
